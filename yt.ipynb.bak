      "\u001b[36mFile \u001b[39m\u001b[32m~/venvs/athena-env/lib/python3.14/site-packages/yt/geometry/coordinates/coordinate_handler.py:329\u001b[39m, in \u001b[36mCoordinateHandler.sanitize_center\u001b[39m\u001b[34m(self, center, axis)\u001b[39m\n\u001b[32m    328\u001b[39m \u001b[38;5;28;01mdef\u001b[39;00m\u001b[38;5;250m \u001b[39m\u001b[34msanitize_center\u001b[39m(\u001b[38;5;28mself\u001b[39m, center, axis):\n\u001b[32m--> \u001b[39m\u001b[32m329\u001b[39m     center = \u001b[43mparse_center_array\u001b[49m\u001b[43m(\u001b[49m\u001b[43mcenter\u001b[49m\u001b[43m,\u001b[49m\u001b[43m \u001b[49m\u001b[43mds\u001b[49m\u001b[43m=\u001b[49m\u001b[38;5;28;43mself\u001b[39;49m\u001b[43m.\u001b[49m\u001b[43mds\u001b[49m\u001b[43m,\u001b[49m\u001b[43m \u001b[49m\u001b[43maxis\u001b[49m\u001b[43m=\u001b[49m\u001b[43maxis\u001b[49m\u001b[43m)\u001b[49m\n\u001b[32m    330\u001b[39m     \u001b[38;5;66;03m# This has to return both a center and a display_center\u001b[39;00m\n\u001b[32m    331\u001b[39m     display_center = \u001b[38;5;28mself\u001b[39m.convert_to_cartesian(center)\n",
      "\u001b[36mFile \u001b[39m\u001b[32m~/venvs/athena-env/lib/python3.14/site-packages/yt/funcs.py:1263\u001b[39m, in \u001b[36mparse_center_array\u001b[39m\u001b[34m(center, ds, axis)\u001b[39m\n\u001b[32m   1258\u001b[39m     center = (match[\u001b[33m\"\u001b[39m\u001b[33mextremum\u001b[39m\u001b[33m\"\u001b[39m], (ftype, fname))\n\u001b[32m   1260\u001b[39m \u001b[38;5;28;01melif\u001b[39;00m centerl \u001b[38;5;129;01min\u001b[39;00m (\u001b[33m\"\u001b[39m\u001b[33mcenter\u001b[39m\u001b[33m\"\u001b[39m, \u001b[33m\"\u001b[39m\u001b[33mleft\u001b[39m\u001b[33m\"\u001b[39m, \u001b[33m\"\u001b[39m\u001b[33mright\u001b[39m\u001b[33m\"\u001b[39m):\n\u001b[32m   1261\u001b[39m     \u001b[38;5;66;03m# domain_left_edge and domain_right_edge might not be\u001b[39;00m\n\u001b[32m   1262\u001b[39m     \u001b[38;5;66;03m# initialized until we create the index, so create it\u001b[39;00m\n\u001b[32m-> \u001b[39m\u001b[32m1263\u001b[39m     \u001b[43mds\u001b[49m\u001b[43m.\u001b[49m\u001b[43mindex\u001b[49m\n\u001b[32m   1264\u001b[39m     center = ds.domain_center.copy()\n\u001b[32m   1265\u001b[39m     \u001b[38;5;28;01mif\u001b[39;00m centerl \u001b[38;5;129;01min\u001b[39;00m (\u001b[33m\"\u001b[39m\u001b[33mleft\u001b[39m\u001b[33m\"\u001b[39m, \u001b[33m\"\u001b[39m\u001b[33mright\u001b[39m\u001b[33m\"\u001b[39m) \u001b[38;5;129;01mand\u001b[39;00m axis \u001b[38;5;129;01mis\u001b[39;00m \u001b[38;5;28;01mNone\u001b[39;00m:\n",
      "\u001b[36mFile \u001b[39m\u001b[32m~/venvs/athena-env/lib/python3.14/site-packages/yt/data_objects/static_output.py:612\u001b[39m, in \u001b[36mDataset.index\u001b[39m\u001b[34m(self)\u001b[39m\n\u001b[32m    610\u001b[39m     oldsettings = np.geterr()\n\u001b[32m    611\u001b[39m     np.seterr(\u001b[38;5;28mall\u001b[39m=\u001b[33m\"\u001b[39m\u001b[33mignore\u001b[39m\u001b[33m\"\u001b[39m)\n\u001b[32m--> \u001b[39m\u001b[32m612\u001b[39m     \u001b[38;5;28;43mself\u001b[39;49m\u001b[43m.\u001b[49m\u001b[43mcreate_field_info\u001b[49m\u001b[43m(\u001b[49m\u001b[43m)\u001b[49m\n\u001b[32m    613\u001b[39m     np.seterr(**oldsettings)\n\u001b[32m    614\u001b[39m \u001b[38;5;28;01mreturn\u001b[39;00m \u001b[38;5;28mself\u001b[39m._instantiated_index\n",
      "\u001b[36mFile \u001b[39m\u001b[32m~/venvs/athena-env/lib/python3.14/site-packages/yt/data_objects/static_output.py:708\u001b[39m, in \u001b[36mDataset.create_field_info\u001b[39m\u001b[34m(self)\u001b[39m\n\u001b[32m    706\u001b[39m             mylog.debug(\u001b[33m\"\u001b[39m\u001b[33mzero common fields, skipping particle union \u001b[39m\u001b[33m'\u001b[39m\u001b[33mnbody\u001b[39m\u001b[33m'\u001b[39m\u001b[33m\"\u001b[39m)\n\u001b[32m    707\u001b[39m \u001b[38;5;28mself\u001b[39m.field_info.setup_extra_union_fields()\n\u001b[32m--> \u001b[39m\u001b[32m708\u001b[39m \u001b[38;5;28;43mself\u001b[39;49m\u001b[43m.\u001b[49m\u001b[43mfield_info\u001b[49m\u001b[43m.\u001b[49m\u001b[43mload_all_plugins\u001b[49m\u001b[43m(\u001b[49m\u001b[38;5;28;43mself\u001b[39;49m\u001b[43m.\u001b[49m\u001b[43mdefault_fluid_type\u001b[49m\u001b[43m)\u001b[49m\n\u001b[32m    709\u001b[39m deps, unloaded = \u001b[38;5;28mself\u001b[39m.field_info.check_derived_fields()\n\u001b[32m    710\u001b[39m \u001b[38;5;28mself\u001b[39m.field_dependencies.update(deps)\n",
      "\u001b[36mFile \u001b[39m\u001b[32m~/venvs/athena-env/lib/python3.14/site-packages/yt/fields/field_info_container.py:417\u001b[39m, in \u001b[36mFieldInfoContainer.load_all_plugins\u001b[39m\u001b[34m(self, ftype)\u001b[39m\n\u001b[32m    415\u001b[39m     loaded += \u001b[38;5;28mself\u001b[39m.load_plugin(n, ftype)\n\u001b[32m    416\u001b[39m     only_on_root(mylog.debug, \u001b[33m\"\u001b[39m\u001b[33mLoaded \u001b[39m\u001b[38;5;132;01m%s\u001b[39;00m\u001b[33m (\u001b[39m\u001b[38;5;132;01m%s\u001b[39;00m\u001b[33m new fields)\u001b[39m\u001b[33m\"\u001b[39m, n, \u001b[38;5;28mlen\u001b[39m(loaded))\n\u001b[32m--> \u001b[39m\u001b[32m417\u001b[39m \u001b[38;5;28;43mself\u001b[39;49m\u001b[43m.\u001b[49m\u001b[43mfind_dependencies\u001b[49m\u001b[43m(\u001b[49m\u001b[43mloaded\u001b[49m\u001b[43m)\u001b[49m\n",
      "\u001b[36mFile \u001b[39m\u001b[32m~/venvs/athena-env/lib/python3.14/site-packages/yt/fields/field_info_container.py:432\u001b[39m, in \u001b[36mFieldInfoContainer.find_dependencies\u001b[39m\u001b[34m(self, loaded)\u001b[39m\n\u001b[32m    431\u001b[39m \u001b[38;5;28;01mdef\u001b[39;00m\u001b[38;5;250m \u001b[39m\u001b[34mfind_dependencies\u001b[39m(\u001b[38;5;28mself\u001b[39m, loaded):\n\u001b[32m--> \u001b[39m\u001b[32m432\u001b[39m     deps, unavailable = \u001b[38;5;28;43mself\u001b[39;49m\u001b[43m.\u001b[49m\u001b[43mcheck_derived_fields\u001b[49m\u001b[43m(\u001b[49m\u001b[43mloaded\u001b[49m\u001b[43m)\u001b[49m\n\u001b[32m    433\u001b[39m     \u001b[38;5;28mself\u001b[39m.ds.field_dependencies.update(deps)\n\u001b[32m    434\u001b[39m     \u001b[38;5;66;03m# Note we may have duplicated\u001b[39;00m\n",
      "\u001b[36mFile \u001b[39m\u001b[32m~/venvs/athena-env/lib/python3.14/site-packages/yt/fields/field_info_container.py:643\u001b[39m, in \u001b[36mFieldInfoContainer.check_derived_fields\u001b[39m\u001b[34m(self, fields_to_check)\u001b[39m\n\u001b[32m    640\u001b[39m fi = \u001b[38;5;28mself\u001b[39m[field]\n\u001b[32m    641\u001b[39m \u001b[38;5;28;01mtry\u001b[39;00m:\n\u001b[32m    642\u001b[39m     \u001b[38;5;66;03m# fd: field detector\u001b[39;00m\n\u001b[32m--> \u001b[39m\u001b[32m643\u001b[39m     fd = \u001b[43mfi\u001b[49m\u001b[43m.\u001b[49m\u001b[43mget_dependencies\u001b[49m\u001b[43m(\u001b[49m\u001b[43mds\u001b[49m\u001b[43m=\u001b[49m\u001b[38;5;28;43mself\u001b[39;49m\u001b[43m.\u001b[49m\u001b[43mds\u001b[49m\u001b[43m)\u001b[49m\n\u001b[32m    644\u001b[39m \u001b[38;5;28;01mexcept\u001b[39;00m blacklist \u001b[38;5;28;01mas\u001b[39;00m err:\n\u001b[32m    645\u001b[39m     \u001b[38;5;28mprint\u001b[39m(\u001b[33mf\u001b[39m\u001b[33m\"\u001b[39m\u001b[38;5;132;01m{\u001b[39;00merr.\u001b[34m__class__\u001b[39m\u001b[38;5;132;01m}\u001b[39;00m\u001b[33m raised for field \u001b[39m\u001b[38;5;132;01m{\u001b[39;00mfield\u001b[38;5;132;01m}\u001b[39;00m\u001b[33m\"\u001b[39m)\n",
      "\u001b[36mFile \u001b[39m\u001b[32m~/venvs/athena-env/lib/python3.14/site-packages/yt/fields/derived_field.py:244\u001b[39m, in \u001b[36mDerivedField.get_dependencies\u001b[39m\u001b[34m(self, *args, **kwargs)\u001b[39m\n\u001b[32m    240\u001b[39m \u001b[38;5;250m\u001b[39m\u001b[33;03m\"\"\"\u001b[39;00m\n\u001b[32m    241\u001b[39m \u001b[33;03mThis returns a list of names of fields that this field depends on.\u001b[39;00m\n\u001b[32m    242\u001b[39m \u001b[33;03m\"\"\"\u001b[39;00m\n\u001b[32m    243\u001b[39m e = FieldDetector(*args, **kwargs)\n\u001b[32m--> \u001b[39m\u001b[32m244\u001b[39m \u001b[43me\u001b[49m\u001b[43m[\u001b[49m\u001b[38;5;28;43mself\u001b[39;49m\u001b[43m.\u001b[49m\u001b[43mname\u001b[49m\u001b[43m]\u001b[49m\n\u001b[32m    245\u001b[39m \u001b[38;5;28;01mreturn\u001b[39;00m e\n",
      "\u001b[36mFile \u001b[39m\u001b[32m~/venvs/athena-env/lib/python3.14/site-packages/yt/fields/field_detector.py:128\u001b[39m, in \u001b[36mFieldDetector.__missing__\u001b[39m\u001b[34m(self, item)\u001b[39m\n\u001b[32m    126\u001b[39m             vv = finfo(\u001b[38;5;28mself\u001b[39m)\n\u001b[32m    127\u001b[39m     \u001b[38;5;28;01mif\u001b[39;00m \u001b[38;5;129;01mnot\u001b[39;00m permute_params:\n\u001b[32m--> \u001b[39m\u001b[32m128\u001b[39m         vv = \u001b[43mfinfo\u001b[49m\u001b[43m(\u001b[49m\u001b[38;5;28;43mself\u001b[39;49m\u001b[43m)\u001b[49m\n\u001b[32m    129\u001b[39m \u001b[38;5;28;01mexcept\u001b[39;00m NeedsGridType \u001b[38;5;28;01mas\u001b[39;00m exc:\n\u001b[32m    130\u001b[39m     ngz = exc.ghost_zones\n",
      "\u001b[36mFile \u001b[39m\u001b[32m~/venvs/athena-env/lib/python3.14/site-packages/yt/fields/derived_field.py:285\u001b[39m, in \u001b[36mDerivedField.__call__\u001b[39m\u001b[34m(self, data)\u001b[39m\n\u001b[32m    280\u001b[39m     \u001b[38;5;28;01mraise\u001b[39;00m \u001b[38;5;167;01mRuntimeError\u001b[39;00m(\n\u001b[32m    281\u001b[39m         \u001b[33m\"\u001b[39m\u001b[33mSomething has gone terribly wrong, _function is NullFunc \u001b[39m\u001b[33m\"\u001b[39m\n\u001b[32m    282\u001b[39m         + \u001b[33mf\u001b[39m\u001b[33m\"\u001b[39m\u001b[33mfor \u001b[39m\u001b[38;5;132;01m{\u001b[39;00m\u001b[38;5;28mself\u001b[39m.name\u001b[38;5;132;01m}\u001b[39;00m\u001b[33m\"\u001b[39m\n\u001b[32m    283\u001b[39m     )\n\u001b[32m    284\u001b[39m \u001b[38;5;28;01mwith\u001b[39;00m \u001b[38;5;28mself\u001b[39m.unit_registry(data):\n\u001b[32m--> \u001b[39m\u001b[32m285\u001b[39m     dd = \u001b[38;5;28;43mself\u001b[39;49m\u001b[43m.\u001b[49m\u001b[43m_function\u001b[49m\u001b[43m(\u001b[49m\u001b[38;5;28;43mself\u001b[39;49m\u001b[43m,\u001b[49m\u001b[43m \u001b[49m\u001b[43mdata\u001b[49m\u001b[43m)\u001b[49m\n\u001b[32m    286\u001b[39m \u001b[38;5;28;01mfor\u001b[39;00m field_name \u001b[38;5;129;01min\u001b[39;00m data.keys():\n\u001b[32m    287\u001b[39m     \u001b[38;5;28;01mif\u001b[39;00m field_name \u001b[38;5;129;01mnot\u001b[39;00m \u001b[38;5;129;01min\u001b[39;00m original_fields:\n",
      "\u001b[36mCell\u001b[39m\u001b[36m \u001b[39m\u001b[32mIn[8]\u001b[39m\u001b[32m, line 8\u001b[39m, in \u001b[36m_gamma\u001b[39m\u001b[34m(field, data)\u001b[39m\n\u001b[32m      6\u001b[39m u2 = data[(\u001b[33m'\u001b[39m\u001b[33mgas\u001b[39m\u001b[33m'\u001b[39m, \u001b[33m'\u001b[39m\u001b[33mfour_velocity_theta\u001b[39m\u001b[33m'\u001b[39m)]\n\u001b[32m      7\u001b[39m u3 = data[(\u001b[33m'\u001b[39m\u001b[33mgas\u001b[39m\u001b[33m'\u001b[39m, \u001b[33m'\u001b[39m\u001b[33mfour_velocity_z\u001b[39m\u001b[33m'\u001b[39m)]\n\u001b[32m----> \u001b[39m\u001b[32m8\u001b[39m \u001b[38;5;28;01mreturn\u001b[39;00m np.sqrt(\u001b[32;43m1\u001b[39;49m\u001b[43m \u001b[49m\u001b[43m+\u001b[49m\u001b[43m \u001b[49m\u001b[43mu1\u001b[49m\u001b[43m*\u001b[49m\u001b[43m*\u001b[49m\u001b[32;43m2\u001b[39;49m + u2**\u001b[32m2\u001b[39m + u3**\u001b[32m2\u001b[39m)\n",
      "\u001b[36mFile \u001b[39m\u001b[32m~/venvs/athena-env/lib/python3.14/site-packages/unyt/array.py:392\u001b[39m, in \u001b[36m_subclass_ufunc_prepare_and_finalize.<locals>.wrapper\u001b[39m\u001b[34m(self, ufunc, method, *inputs, **kwargs)\u001b[39m\n\u001b[32m    385\u001b[39m \u001b[38;5;28;01melse\u001b[39;00m:\n\u001b[32m    386\u001b[39m     prepared_ufunc, prepared_method, prepared_inputs, prepared_kwargs = (\n\u001b[32m    387\u001b[39m         ufunc,\n\u001b[32m    388\u001b[39m         method,\n\u001b[32m    389\u001b[39m         inputs,\n\u001b[32m    390\u001b[39m         kwargs,\n\u001b[32m    391\u001b[39m     )\n\u001b[32m--> \u001b[39m\u001b[32m392\u001b[39m result = \u001b[43mufunc_handler\u001b[49m\u001b[43m(\u001b[49m\n\u001b[32m    393\u001b[39m \u001b[43m    \u001b[49m\u001b[38;5;28;43mself\u001b[39;49m\u001b[43m,\u001b[49m\n\u001b[32m    394\u001b[39m \u001b[43m    \u001b[49m\u001b[43mprepared_ufunc\u001b[49m\u001b[43m,\u001b[49m\n\u001b[32m    395\u001b[39m \u001b[43m    \u001b[49m\u001b[43mprepared_method\u001b[49m\u001b[43m,\u001b[49m\n\u001b[32m    396\u001b[39m \u001b[43m    \u001b[49m\u001b[43m*\u001b[49m\u001b[43mprepared_inputs\u001b[49m\u001b[43m,\u001b[49m\n\u001b[32m    397\u001b[39m \u001b[43m    \u001b[49m\u001b[43m*\u001b[49m\u001b[43m*\u001b[49m\u001b[43mprepared_kwargs\u001b[49m\u001b[43m,\u001b[49m\n\u001b[32m    398\u001b[39m \u001b[43m\u001b[49m\u001b[43m)\u001b[49m\n\u001b[32m    399\u001b[39m \u001b[38;5;28;01mif\u001b[39;00m \u001b[38;5;28mhasattr\u001b[39m(ret_class, \u001b[33m\"\u001b[39m\u001b[33m__unyt_ufunc_finalize__\u001b[39m\u001b[33m\"\u001b[39m):\n\u001b[32m    400\u001b[39m     \u001b[38;5;28;01mreturn\u001b[39;00m ret_class.__unyt_ufunc_finalize__(\n\u001b[32m    401\u001b[39m         result, ufunc, method, *inputs, **kwargs\n\u001b[32m    402\u001b[39m     )\n",
      "\u001b[36mFile \u001b[39m\u001b[32m~/venvs/athena-env/lib/python3.14/site-packages/unyt/array.py:2022\u001b[39m, in \u001b[36munyt_array.__array_ufunc__\u001b[39m\u001b[34m(self, ufunc, method, *inputs, **kwargs)\u001b[39m\n\u001b[32m   2020\u001b[39m                 \u001b[38;5;28;01mraise\u001b[39;00m UnitOperationError(ufunc, u0, u1)\n\u001b[32m   2021\u001b[39m     \u001b[38;5;28;01melse\u001b[39;00m:\n\u001b[32m-> \u001b[39m\u001b[32m2022\u001b[39m         \u001b[38;5;28;01mraise\u001b[39;00m UnitOperationError(ufunc, u0, u1)\n\u001b[32m   2023\u001b[39m conv, offset = u1.get_conversion_factor(u0, inp1.dtype)\n\u001b[32m   2024\u001b[39m new_dtype = np.dtype(\u001b[33m\"\u001b[39m\u001b[33mf\u001b[39m\u001b[33m\"\u001b[39m + \u001b[38;5;28mstr\u001b[39m(inp1.dtype.itemsize))\n",
      "\u001b[31mUnitOperationError\u001b[39m: The <ufunc 'add'> operator for unyt_arrays with units 'dimensionless' (dimensions '1') and 'code_length**2/code_time**2' (dimensions '(length)**2/(time)**2') is not well defined."
     ]
    }
   ],
   "source": [
    "import yt\n",
    "from pathlib import Path\n",
    "#DEFINE GAMMA FIELD FOR YT AS (1+ u_1u_1+u_2u_2+u_3u_3)^{1/2}\n",
    "def _gamma(field, data):\n",
    "    u1 = data[('gas', 'four_velocity_r')]\n",
    "    u2 = data[('gas', 'four_velocity_theta')]\n",
    "    u3 = data[('gas', 'four_velocity_z')]\n",
    "    c = data.ds.quan(1.0, 'code_velocity')\n",
    "    return (1 + (u1/c)**2 + (u2/c)**2 + (u3/c)**2)**0.5\n",
    "\n",
    "yt.add_field(('gas', 'lorentz_gamma'), function=_gamma, units=\"\", sampling_type = \"cell\", dimensions = yt.units.dimensionless)\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "ds = yt.load('/scratch/aripoll/athena_out/outputs/jet_blast.out1.00150.athdf')\n",
    "nx, ny = ds.domain_dimensions[0], ds.domain_dimensions[1]\n",
    "print(ds)\n",
    "# print(ds.current_time)\n",
    "# #print(ds.field_list)        # native fields\n",
    "# print(ds.derived_field_list)\n",
    "p = yt.SlicePlot(ds, \"z\", ('gas', 'lorentz_gamma'))\n",
    "p.annotate_timestamp(corner=\"upper_left\", text_args={\"color\": \"black\"}, time_format=r\"$t = {time:.2f}\\ R_{{*}}/c$\")\n",
    "p.set_xlabel(r\"x $[R_{*}]$\")\n",
    "p.set_ylabel(r\"y $[R_{*}]$\")\n",
    "p.set_colorbar_label((\"gas\", \"lorentz_gamma\"), r\" Lorentz Factor $\\gamma$\")\n",
    "\n",
    "#p.annotate_text((0.3, 0.001), rf\"$\\tilde{{L}}= {L_tilde:.2e} \\text{{ and }} E/{{mc^2}}= {Emc2:.2e}$\", coord_system=\"figure\", text_args={\"color\": \"black\"})\n",
    "p.annotate_title(\"{}x{}\".format(nx, ny))\n"
