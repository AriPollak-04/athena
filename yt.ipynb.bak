   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 1D velocity profile at a fixed azimuthal angle\n",
    "theta_vals = np.linspace(0, 2*np.pi, 80)  # example theta values\n",
    "z_val     = 0.5   #doesnt matter\n",
    "\n",
    "# Shock front = outermost r where v_r exceeds threshold (matches athinput breakout_vmin)\n",
    "v_threshold = 0.01\n",
    "r_max = []\n",
    "\n",
    "for theta_val in theta_vals:\n",
    "    ray = ds.ortho_ray(0, (theta_val, z_val))  # ray along r at fixed (theta, z)\n",
    "\n",
    "    df = ray.to_dataframe([('index', 'r'), ('gas', 'velocity_r')])\n",
    "    df = df.sort_values('r').reset_index(drop=True)\n",
    "\n",
    "    # Shock front = OUTERMOST r where v_r exceeds threshold.\n",
    "    # idxmax() finds the velocity peak (jet interior), not the outer shock edge.\n",
    "    mask = df['velocity_r'] > v_threshold\n",
    "    r_max.append(df.loc[mask, 'r'].max() if mask.any() else np.nan)\n",
    "\n",
    "    #Now plot the velocity profile for each theta\n",
    "    # fig, ax = plt.subplots()\n",
    "    # ax.plot(df['r'], df['velocity_r'], label='Radial Velocity')\n",
    "    # ax.axvline(r_max[-1], color='r', linestyle='--', label=f'shock r={r_max[-1]:.3f}')\n",
    "    # ax.set_xlabel(r\"$r \\ [R_*]$\")\n",
    "    # ax.set_ylabel(r\"$v_r \\ [c]$\")\n",
    "    # ax.set_title(rf\"Radial velocity at $\\theta = {theta_val:.3f}$ rad, $t = {float(ds.current_time):.2f}\\ R_*/c$\") \n",
    "    # ax.legend()\n",
    "    # plt.show()\n",
    "\n",
    "# Plot shock radius vs theta in a polar plot\n",
    "plt.figure()\n",
    "plt.polar(theta_vals, r_max, marker='o')\n",
    "plt.title(rf\"Shock radius vs $\\theta$ at $t = {float(ds.current_time):.2f}\\ R_*/c$\")\n",
    "plt.show()"
   ]
  },
