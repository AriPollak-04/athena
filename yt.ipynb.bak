   "source": [
    "#Computing everuthing beforehand\n",
    "import numpy as np\n",
    "import sympy as sp\n",
    "M = 1 #Mass of the star in code units\n",
    "R = 1 #Radius of the star in code units\n",
    "c = 1 #Speed of light in code units\n",
    "G = 1 #Gravitational constant in code units\n",
    "\n",
    "\n",
    "\n",
    "rho_j = 0.28 # M*R^-3\n",
    "P_j = 1e-6  #G*M^2*R^-4\n",
    "h = 1+ 4*(P_j/rho_j)\n",
    "Gamma = 20 #p['problem']['jet_Gam']\n",
    "v = c*np.sqrt(1-1/(Gamma**2))\n",
    "r_inj = 0.01 # R\n",
    "th_inj = 0.174533 # p['problem']['theta_0']\n",
    "\n",
    "t_stop = 4.8 # p['problem']['t_stop'] # R/c\n",
    "\n",
    "\n",
    "\n",
    "L_jet = 2*rho_j*h*Gamma**2*v*np.pi*r_inj**2*np.sin(th_inj)**2 #Multiply by 2 for both jets\n",
    "L_jet = sp.simplify(L_jet)\n",
    "\n",
    "E_jet = L_jet*t_stop\n",
    "\n",
    "#now lets make some dimensionless quantities for the jet's luminosity and energy\n",
    "import pandas as pd\n",
    "Emc2 = E_jet / (M * c**2)\n",
    "rho_01 = 12.904398355133837\n",
    "L_tilde = rho_j/rho_01 * h *Gamma**2 * v* c**-3\n",
    "L_tilde = sp.simplify(L_tilde)\n",
    "print(L_tilde)\n",
    "print(Emc2)\n",
    "1e-2"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "kuhq8ak8ki",
   "metadata": {},
   "outputs": [],
   "source": [
    "import re\n",
    "#Reading in the athinput file\n",
    "def read_athinput(path):\n",
    "    \"\"\"Parse an Athena++ input file into a nested dict of {section: {key: value}}.\"\"\"\n",
    "    params = {}\n",
    "    section = None\n",
    "    with open(path) as f:\n",
    "        for line in f:\n",
    "            line = line.strip()\n",
    "            if not line or line.startswith('#'):\n",
    "                continue\n",
    "            # Section header e.g. <problem>\n",
    "            m = re.match(r'^<(\\w+)>$', line)\n",
    "            if m:\n",
    "                section = m.group(1)\n",
    "                if section != 'comment':\n",
    "                    params[section] = {}\n",
    "                continue\n",
    "            # Key-value pair\n",
    "            if section and section != 'comment' and '=' in line:\n",
    "                key, _, rest = line.partition('=')\n",
    "                value = rest.split('#')[0].strip()\n",
    "                key = key.strip()\n",
    "                try:\n",
    "                    value = int(value)\n",
    "                except ValueError:\n",
    "                    try:\n",
    "                        value = float(value)\n",
    "                    except ValueError:\n",
    "                        pass  # keep as string\n",
    "                params[section][key] = value\n",
    "    return params\n",
    "\n"
   ]
  },
