   "source": [
    "import yt\n",
    "from pathlib import Path\n",
    "import subprocess\n",
    "frames_dir = Path('/scratch/aripoll/athena_out/frames')\n",
    "frames_dir.mkdir(parents=True, exist_ok=True)\n",
    "mp4_path = str(\"/scratch/aripoll/athena/VEL_FixL_Crit_t_4_8.mp4\")\n",
    "subprocess.run([\n",
    "    \"ffmpeg\", \"-y\",\n",
    "    \"-framerate\", \"24\",\n",
    "    \"-i\", str(frames_dir / \"vel_frame_%05d.png\"),\n",
    "    \"-c:v\", \"libx264\",\n",
    "    \"-pix_fmt\", \"yuv420p\",\n",
    "    \"-vf\", \"pad=ceil(iw/2)*2:ceil(ih/2)*2\",\n",
    "    mp4_path\n",
    "], check=True)\n",
    "\n",
    "from IPython.display import Video, display\n",
    "display(Video(mp4_path, embed=True))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3a336cf6",
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 1D velocity profile at a fixed azimuthal angle\n",
    "# theta = 2*pi is identical to theta = 0 (periodic BC); use any angle in [0, 2*pi)\n",
    "theta_val = 0.0   # radians\n",
    "z_val     = 0.5   # only 1 z-cell, so this value doesn't matter\n",
    "\n",
    "ray = ds.ortho_ray(0, (theta_val, z_val))  # ray along r at fixed (theta, z)\n",
    "\n",
    "df = ray.to_dataframe([('index', 'r'), ('athena_pp', 'vel1')])\n",
    "df = df.sort_values('r').reset_index(drop=True)\n",
    "\n",
    "fig, ax = plt.subplots()\n",
    "ax.plot(df['r'], df['vel1'])\n",
    "ax.set_xlabel(r\"$r \\ [R_*]$\")\n",
    "ax.set_ylabel(r\"$v_r \\ [c]$\")\n",
    "ax.set_title(rf\"Radial velocity at $\\theta = {theta_val:.3f}$ rad, $t = {float(ds.current_time):.2f}\\ R_*/c$\")\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "bfac5aa4",
   "metadata": {},
   "outputs": [],
